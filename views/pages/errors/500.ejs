<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../partials/head', { title: title }) %>
</head>
<body class="site-body">
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <%- include('../../partials/navbar', { currentPage: currentPage }) %>

  <main id="main-content" class="main-content">

    <section class="section" style="text-align:center;min-height:70vh;display:flex;align-items:center;justify-content:center;">
      <div class="container">

        <!-- Error Code -->
        <div data-aos="fade-up">
          <span class="text-mono" style="font-size:var(--text-sm);color:var(--color-error);display:block;margin-bottom:var(--space-4);">
            ~/errors
          </span>
          <p style="font-size:clamp(6rem,15vw,10rem);font-weight:700;line-height:1;color:var(--color-text-muted);opacity:0.25;">
            500
          </p>
        </div>

        <!-- Message -->
        <div data-aos="fade-up" data-aos-delay="100">
          <h1 class="heading-2" style="margin-bottom:var(--space-4);">
            Something went wrong.
          </h1>
          <p class="text-muted" style="max-width:420px;margin:0 auto var(--space-8);">
            An unexpected error occurred on the server. This has been logged
            and will be investigated. Please try again later.
          </p>
        </div>

        <!-- Actions -->
        <div data-aos="fade-up" data-aos-delay="200" style="display:flex;gap:var(--space-4);justify-content:center;flex-wrap:wrap;">
          <a href="/" class="btn btn--primary">
            <i class="fas fa-home" aria-hidden="true"></i>
            Go Home
          </a>
          <a href="/contact" class="btn btn--ghost">
            Report Issue
          </a>
        </div>

      </div>
    </section>

  </main>

  <%- include('../../partials/footer') %>
  <%- include('../../partials/scripts') %>
</body>
</html>