<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head', { title: 'Projects — Nash Francis' }) %>
</head>
<body class="site-body">
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <%- include('../partials/navbar', { currentPage: 'projects' }) %>

  <main id="main-content" class="main-content">

    <!-- ── PAGE HEADER ───────────────────────────────────────── -->
    <section class="page-header">
      <div class="page-header__grid-bg" aria-hidden="true"></div>
      <div class="container">
        <span class="section-label" data-aos="fade-up">Selected Work</span>
        <h1 class="heading-1" data-aos="fade-up" data-aos-delay="100">
          Projects I've built.
        </h1>
        <p class="text-muted" style="max-width:480px;margin:var(--space-4) auto 0;" data-aos="fade-up" data-aos-delay="150">
          A selection of full-stack projects — from concept to deployment.
        </p>
      </div>
    </section>

    <!-- ── PROJECTS GRID ───────────────────────────────────────── -->
    <section class="section projects-section" aria-label="Project portfolio">
      <div class="container">
        <% if (projects && projects.length > 0) { %>
          <div class="projects-grid">
            <% projects.forEach((project, i) => { %>
              <article class="project-card card" data-aos="fade-up" data-aos-delay="<%= i * 100 %>">
                <div class="project-card__header">
                  <div class="project-card__tags">
                    <% project.tags.forEach(tag => { %>
                      <span class="tag"><%= tag %></span>
                    <% }) %>
                  </div>
                  <div class="project-card__links">
                    <% if (project.githubUrl) { %>
                      <a href="<%= project.githubUrl %>" class="project-card__link" title="View source on GitHub">
                        <i class="fab fa-github" aria-hidden="true"></i>
                      </a>
                    <% } %>
                    <% if (project.liveUrl) { %>
                      <a href="<%= project.liveUrl %>" class="project-card__link" title="View live site">
                        <i class="fas fa-external-link-alt" aria-hidden="true"></i>
                      </a>
                    <% } %>
                  </div>
                </div>
                
                <h3 class="heading-3">
                  <a href="/projects/<%= project.id %>" class="project-card__title">
                    <%= project.title %>
                  </a>
                </h3>
                
                <p class="text-muted"><%= project.summary %></p>
                
                <a href="/projects/<%= project.id %>" class="btn btn--ghost btn--sm">
                  View Case Study
                  <i class="fas fa-arrow-right" aria-hidden="true"></i>
                </a>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-state">
            <p class="text-muted">No projects yet. Check back soon!</p>
          </div>
        <% } %>
      </div>
    </section>

  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/scripts') %>
</body>
</html>