<!-- AOS: Animate On Scroll (async + defer for non-blocking load) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js" async defer></script>

<!-- Main Application Script -->
<script src="/js/main.js" defer></script>

<!-- Page-specific scripts (loaded after main) -->
<% if (typeof pageScript !== 'undefined' && pageScript) { %>
  <script src="/js/<%= pageScript %>" defer></script>
<% } %>
